# --- Copia a .env y rellena ---

# Token del bot (@BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC...

# Tu ID numérico de Telegram (único admin). /start te lo dice si no lo sabes.
TELEGRAM_ADMIN_ID=

# Carpeta raíz de proyectos (el browser de /open empieza aquí)
DEFAULT_WORKSPACE=/home/valle/proyectos

# Permisos de Claude por defecto:
#   bypassPermissions  -> hace todo sin preguntar (por defecto)
#   acceptEdits        -> edita sin preguntar, pregunta comandos
#   default            -> pregunta (botones) en cada acción
#   plan               -> solo planifica
PERMISSION_MODE=bypassPermissions

# Transcripción de notas de voz (X.AI Grok STT). Opcional.
XAI_API_KEY=

# Límite por tarea en segundos: si Claude se cuelga o supera este tiempo, la
# tarea se interrumpe, se libera la sesión y se avisa por Telegram.
TASK_TIMEOUT=1800
